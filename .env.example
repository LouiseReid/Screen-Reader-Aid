# Code signing + notarization for `npm run make` (macOS, Path C — Developer ID).
# Copy this file to `.env` and fill it in. `.env` is gitignored — NEVER commit real
# values. Without any of these, `npm run make` still works but produces an UNSIGNED
# build (fine for local use; other Macs will show a Gatekeeper warning).

# Enable signing. Set to 1 once you have a "Developer ID Application" certificate in
# your login Keychain. (Treated as enabled automatically if APPLE_IDENTITY is set.)
APPLE_SIGN=0

# Optional: the exact signing identity. Leave blank to auto-detect the Developer ID
# Application certificate from your Keychain. List available identities with:
#   security find-identity -v -p codesigning
# APPLE_IDENTITY=Developer ID Application: Your Name (TEAMID)

# Notarization (Apple notary service via notarytool). All three are required to
# notarize; if any is missing the build is signed but NOT notarized.
#   APPLE_ID                     - your Apple Developer account email
#   APPLE_APP_SPECIFIC_PASSWORD  - create at https://appleid.apple.com
#                                  (Sign-In & Security > App-Specific Passwords);
#                                  this is NOT your normal Apple ID password
#   APPLE_TEAM_ID                - 10-char Team ID from
#                                  https://developer.apple.com/account (Membership)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
